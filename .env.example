# ===== App =====
APP_NAME=JadeAI

# ===== Auth =====
AUTH_ENABLED=false
AUTH_SECRET=your-auth-secret-key-change-me

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===== Database =====
DB_TYPE=sqlite

# PostgreSQL (when DB_TYPE=postgresql)
DATABASE_URL=postgresql://user:password@localhost:5432/jadeai

# SQLite (when DB_TYPE=sqlite)
SQLITE_PATH=./data/jade.db

# ===== i18n =====
DEFAULT_LOCALE=zh

# ===== ZPAY 支付 =====
# 从 http://www.z-pay.cn 注册获取
ZPAY_PID=your_zpay_pid
ZPAY_KEY=your_zpay_key
# 从 https://www.xunhupay.com 注册获取
XUNHU_APPID=your_xunhu_appid
XUNHU_APPSECRET=your_xunhu_appsecret
# 从 https://dashboard.stripe.com/test/apikeys 获取
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_LIFETIME_PRICE_ID=price_xxxxxxxxxxxxx
# 从 Stripe Dashboard > Webhooks 创建 endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx


